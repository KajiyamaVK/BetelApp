JWT_SECRET=CHANGE_ME_32_CHARS_MIN
MINIO_ENDPOINT=s3.kajiyama.com.br
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=betelsas-content
