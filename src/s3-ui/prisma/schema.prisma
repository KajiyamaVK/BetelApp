generator client {
  provider = "prisma-client-js"
}

// Prisma v7: database URL is configured in prisma.config.ts via defineConfig({ datasource: { url: env('DATABASE_URL') } })
// The url field is intentionally absent here — it is not read from this block in v7.
datasource db {
  provider = "postgresql"
}

model User {
  id                 Int               @id @default(autoincrement())
  username           String            @unique
  passwordHash       String
  isAdmin            Boolean           @default(false)
  mustChangePassword Boolean           @default(true)
  createdAt          DateTime          @default(now())
}

model Lesson {
  id            Int      @id
  order         Int      @default(0) @unique
  title         String
  published     Boolean  @default(false)
  pdfActive     String?
  pdfChecksum   String?
  pdfHistory    Json     @default("[]")
  audioActive   String?
  audioExt      String?
  audioChecksum String?
  audioHistory  Json     @default("[]")
}

// Audit log for lesson mutations. lessonId is stored as a plain Int (no FK)
// so the history survives even after the lesson is deleted.
model LessonAuditLog {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  userId    Int
  action    String
  createdAt DateTime @default(now())
}

model Question {
  id        Int       @id @default(autoincrement())
  lessonId  Int
  question  String
  answer    String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

// Audit log for question deletes. questionId and lessonId are plain Ints (no FK)
// so the history survives even after the question or lesson is deleted.
model QuestionAuditLog {
  id         Int      @id @default(autoincrement())
  questionId Int
  lessonId   Int
  question   String
  answer     String
  deletedBy  String
  deletedAt  DateTime @default(now())
}

// Dynamic content managed via the portal and consumed by the mobile app's BetelDialog.
// type is a plain String ('TEXT' or 'VIDEO') rather than an enum for extensibility.
// slug is auto-generated from title (lowercase, spaces→dashes, accents stripped).
// Multi-page TEXT: parent row is metadata-only (title, slug, published);
// child rows hold per-page HTML via parentId + pageIndex.
model Content {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  type        String   // 'TEXT' or 'VIDEO'
  youtubeUrl  String?
  htmlPath    String?  // MinIO path: contents/{id}/content.html
  published   Boolean  @default(false)
  order       Int      @default(0)
  parentId    Int?
  pageIndex   Int?     // 0-based page position within a multi-page group
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Content?  @relation("ContentPages", fields: [parentId], references: [id], onDelete: Cascade)
  children    Content[] @relation("ContentPages")

  @@index([parentId])
}
