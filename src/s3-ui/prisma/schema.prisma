generator client {
  provider = "prisma-client-js"
}

// Prisma v7: database URL is configured in prisma.config.ts via defineConfig({ datasource: { url: env('DATABASE_URL') } })
// The url field is intentionally absent here — it is not read from this block in v7.
datasource db {
  provider = "postgresql"
}

model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  passwordHash       String
  isAdmin            Boolean  @default(false)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model Lesson {
  id            Int     @id
  title         String
  published     Boolean @default(false)
  pdfActive     String?
  pdfChecksum   String?
  pdfHistory    Json    @default("[]")
  audioActive   String?
  audioExt      String?
  audioChecksum String?
  audioHistory  Json    @default("[]")
}
